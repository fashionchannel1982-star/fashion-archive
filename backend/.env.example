# ── Required ──────────────────────────────────────────────────────────────────
TWELVE_LABS_API_KEY=
TWELVE_LABS_INDEX_ID=        # returned by ingest.py on first run
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://localhost/fashion_archive

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (defaults to localhost:3000 for dev)
CORS_ORIGINS=http://localhost:3000

# ── Optional / prod ───────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000   # public-facing base URL (used in HLS links)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Confidence calibration (Phase D) ─────────────────────────────────────────
# Logistic curve: calibrated = 100 / (1 + exp(-CONF_K * (raw_cos - CONF_X0)))
# Defaults tuned from corpus (Phase D baseline): k=40, x0=0.065
# CONF_K=40
# CONF_X0=0.065
# Minimum calibrated confidence (0-100) returned by /api/search.
# Default 60 aligns with the display-bucket suppression threshold from CLAUDE.md spec.
# Lower to 50 to surface marginal hits (raw cos ≈ 0.063-0.068).
# SEARCH_CONFIDENCE_FLOOR=60
# Max moments returned per show for concept queries (no brand filter).
# Increase to let one show dominate; decrease for cross-brand diversity.
# MAX_MOMENTS_PER_SHOW=3

# ── Admin endpoint auth ───────────────────────────────────────────────────────
# Bearer token for GET /api/admin/events.
# If unset, the endpoint returns 401 for all requests (fail-closed).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Throttle /api/search per IP to protect the Marengo embed API quota.
# Format: "<count>/<period>" where period is second/minute/hour/day.
# Default: 30/minute. Set higher for trusted internal use, lower for public demos.
# SEARCH_RATE_LIMIT=30/minute

# ── Observability (Step 8 — no-op when unset) ────────────────────────────────
SENTRY_DSN=
