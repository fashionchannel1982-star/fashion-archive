# ── Required ──────────────────────────────────────────────────────────────────
TWELVE_LABS_API_KEY=
TWELVE_LABS_INDEX_ID=        # returned by ingest.py on first run
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://localhost/fashion_archive

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (defaults to localhost:3000 for dev)
CORS_ORIGINS=http://localhost:3000

# ── Optional / prod ───────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000   # public-facing base URL (used in HLS links)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Observability (Step 8 — no-op when unset) ────────────────────────────────
SENTRY_DSN=
